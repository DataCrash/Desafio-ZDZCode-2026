#!/usr/bin/env bash
set -euo pipefail

msg_file="$1"
subject="$(head -n 1 "$msg_file")"

if grep -Eq 'ï¿¿|�|\xEF\xBF\xBD' <<<"$subject"; then
  echo "[commit-msg] Erro: subject com mojibake detectado." >&2
  echo "[commit-msg] Subject atual: $subject" >&2
  echo "[commit-msg] Ajuste o encoding para UTF-8 e tente novamente." >&2
  exit 1
fi

if [[ ! "$subject" =~ ^[^[:alnum:][:space:]]+[[:space:]]+[a-z]+(\([a-zA-Z0-9._/-]+\))?:[[:space:]].+ ]]; then
  echo "[commit-msg] Erro: subject fora do padrao esperado." >&2
  echo "[commit-msg] Formato: <emoji> tipo(escopo opcional): descricao" >&2
  exit 1
fi
